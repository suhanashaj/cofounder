rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && 
        (user.role == 'admin' || request.auth.token.email in ["appadmin@gmail.com", "admin@example.com"]);
    }

    // Help Center Messages: Anyone can create, only admin can manage
    match /helpMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Users collection: Publicly readable for authenticated users (to find co-founders),
    // but only owner or admin can update.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Connections: Parties involved can read/write
    match /connections/{connectionId} {
      allow read, write: if request.auth != null; // Keeping simple for now to avoid breaking existing logic
    }

    // Conversations / Messages: Parties involved can read/write
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
  }
}
